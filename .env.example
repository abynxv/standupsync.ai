# StandupSync — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.

# ─── Database ─────────────────────────────────────────────────────────────────
# Full connection string (used locally / in Docker Compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/standupsync

# Individual vars (used in Kubernetes — app builds the URI from these)
# POSTGRES_SERVER=postgres-service
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=standupsync

# ─── Redis / Celery ───────────────────────────────────────────────────────────
# Port 6380 locally to avoid conflicts with a locally-installed Redis (6379)
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0

# ─── Security ─────────────────────────────────────────────────────────────────
# JWT signing secret — generate a real one:
#   python -c "import secrets; print(secrets.token_hex(32))"
# NEVER use the default in production.
SECRET_KEY=DEVELOPMENT_SECRET_KEY_CHANGE_IN_PRODUCTION

# Token expiry in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── AI ───────────────────────────────────────────────────────────────────────
# Google Gemini API key — get a free key at https://aistudio.google.com/
# Leave blank to disable AI summaries (app still works, returns placeholder text)
GEMINI_API_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
# In production replace with your real domain, e.g.:
#   FRONTEND_ORIGINS=https://app.yourdomain.com
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000
